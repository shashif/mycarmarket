# ==========================================
# MyCarMarket
# File: .env
# Local Development Environment
# Description: Local environment variables for Django, Email and Stripe secrets
# ==========================================

# ==========================================
# DJANGO
# ==========================================

DJANGO_SECRET_KEY=temporary_local_key

DJANGO_DEBUG=True

DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0,mycarmarket.com.au,www.mycarmarket.com.au

CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://mycarmarket.com.au,https://www.mycarmarket.com.au

SITE_URL=http://127.0.0.1:8000


# ==========================================
# EMAIL
# ==========================================

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

EMAIL_HOST=smtp.gmail.com

EMAIL_PORT=587

EMAIL_USE_TLS=True

EMAIL_HOST_USER=

EMAIL_HOST_PASSWORD=

DEFAULT_FROM_EMAIL=MyCarMarket Australia <no-reply@mycarmarket.com.au>

CONTACT_EMAIL=support@mycarmarket.com.au


# ==========================================
# STRIPE SECRET KEYS ONLY
# Price IDs are now controlled from:
# Admin → Core → Site Settings → Stripe Payment Settings
# ==========================================

STRIPE_SECRET_KEY=

STRIPE_PUBLISHABLE_KEY=

STRIPE_WEBHOOK_SECRET=
